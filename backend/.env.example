# Configuration du serveur
PORT=5000
NODE_ENV=development

# Base de données MongoDB
MONGODB_URI=mongodb://localhost:27017/pfe_gps_tracking

# Authentification JWT
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production
JWT_EXPIRES_IN=7d

# CORS - origines autorisees (dashboard React + app mobile en dev)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
